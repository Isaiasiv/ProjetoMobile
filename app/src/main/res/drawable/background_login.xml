<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color1" />
        </shape>
    </item>
    <!-- Camada com a curva no canto superior -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/color5"/>
            <corners android:bottomRightRadius="800dp" />
        </shape>
    </item>

    <!-- Camada do gradiente radial -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.45"
                android:centerY="0.0"
                android:startColor="@color/color5"
                android:centerColor="@color/color3"
            <corners android:radius="0dp" />
        </shape>
    </item>

</layer-list>
